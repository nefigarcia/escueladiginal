
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Security Rules
     * Optimized for collection list operations and school-based multi-tenancy.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffRoleData() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data;
    }

    function isOperationalStaff() {
      let roleData = getStaffRoleData();
      return isSignedIn() && (roleData.role == 'Administrador' || roleData.role == 'Academico');
    }

    function isAdmin() {
      let roleData = getStaffRoleData();
      return isSignedIn() && roleData.role == 'Administrador';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /schools/{schoolId} {
      // Allow public read to verify activation codes during registration
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isAdmin() && resource.data.directorId == request.auth.uid;
    }

    match /staff_roles/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isAdmin() || isOwner(userId));
      allow delete: if isSignedIn() && isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn() && (
        let roleData = getStaffRoleData();
        (roleData.role == 'Administrador' || roleData.role == 'Academico') && resource.data.schoolId == roleData.schoolId ||
        (roleData.role == 'Alumno' && resource.data.schoolId == roleData.schoolId && resource.data.studentIdNumber == roleData.studentIdNumber)
      );
      
      allow create: if isSignedIn() && isOperationalStaff() && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow update: if isSignedIn() && isOperationalStaff() && resource.data.schoolId == getStaffRoleData().schoolId;
      allow delete: if isSignedIn() && isAdmin() && resource.data.schoolId == getStaffRoleData().schoolId;
      
      match /payments/{paymentId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/students/$(studentId)).data.schoolId == getStaffRoleData().schoolId;
        allow create, update, delete: if isSignedIn() && isOperationalStaff() && get(/databases/$(database)/documents/students/$(studentId)).data.schoolId == getStaffRoleData().schoolId;
      }
    }

    match /fee_types/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaffRoleData().schoolId;
      allow create: if isSignedIn() && isAdmin() && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow update, delete: if isSignedIn() && isAdmin() && resource.data.schoolId == getStaffRoleData().schoolId;
    }
    
    match /schedules/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaffRoleData().schoolId;
      allow create: if isSignedIn() && isOperationalStaff() && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow update, delete: if isSignedIn() && isOperationalStaff() && resource.data.schoolId == getStaffRoleData().schoolId;
    }

    match /psychology_reports/{reportId} {
      allow read: if isSignedIn() && (
        let roleData = getStaffRoleData();
        (roleData.role == 'Administrador' || roleData.role == 'Academico') && resource.data.schoolId == roleData.schoolId
      );
      allow create: if isSignedIn() && isOperationalStaff() && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow update: if isSignedIn() && (
        let roleData = getStaffRoleData();
        (roleData.role == 'Administrador' || (roleData.role == 'Academico' && resource.data.authorId == request.auth.uid)) && 
        resource.data.schoolId == roleData.schoolId
      );
      allow delete: if isSignedIn() && isAdmin() && resource.data.schoolId == getStaffRoleData().schoolId;
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaffRoleData().schoolId;
      allow create, update: if isSignedIn() && isOperationalStaff() && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow delete: if isSignedIn() && isAdmin() && resource.data.schoolId == getStaffRoleData().schoolId;
    }

    match /grades/{id} {
      allow read: if isSignedIn() && (
        let roleData = getStaffRoleData();
        (roleData.role == 'Administrador' || roleData.role == 'Academico') && resource.data.schoolId == roleData.schoolId ||
        (roleData.role == 'Alumno' && resource.data.schoolId == roleData.schoolId && resource.data.studentIdNumber == roleData.studentIdNumber)
      );
      allow create, update: if isSignedIn() && isOperationalStaff() && request.resource.data.schoolId == getStaffRoleData().schoolId;
      allow delete: if isSignedIn() && isAdmin() && resource.data.schoolId == getStaffRoleData().schoolId;
    }
  }
}
