
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Security Rules
     * Optimized for collection list operations and school-based multi-tenancy.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getStaffData() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data;
    }

    function isOperationalStaff() {
      let staff = getStaffData();
      return isSignedIn() && (staff.role == 'Administrador' || staff.role == 'Academico');
    }

    function isAdmin() {
      let staff = getStaffData();
      return isSignedIn() && staff.role == 'Administrador';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isAdmin() && resource.data.directorId == request.auth.uid;
    }

    match /staff_roles/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (getStaffData().schoolId != null));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || isOwner(userId));
      allow delete: if isSignedIn() && isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn() && (
        let staff = getStaffData();
        (staff.schoolId == resource.data.schoolId)
      );
      
      allow create, update: if isSignedIn() && isOperationalStaff();
      allow delete: if isSignedIn() && isAdmin();
      
      match /payments/{paymentId} {
        allow read: if isSignedIn() && getStaffData().schoolId == get(/databases/$(database)/documents/students/$(studentId)).data.schoolId;
        allow create, update, delete: if isSignedIn() && isOperationalStaff();
      }
    }

    match /fee_types/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaffData().schoolId;
      allow create, update, delete: if isSignedIn() && isAdmin();
    }
    
    match /schedules/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaffData().schoolId;
      allow create, update, delete: if isSignedIn() && isOperationalStaff();
    }

    match /psychology_reports/{reportId} {
      // Regla simplificada para permitir listados filtrados por schoolId
      allow read: if isSignedIn() && (
        let staff = getStaffData();
        (staff.role == 'Administrador' || staff.role == 'Academico') &&
        (resource == null || resource.data.schoolId == staff.schoolId)
      );
      allow create, update: if isSignedIn() && isOperationalStaff();
      allow delete: if isSignedIn() && isAdmin();
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getStaffData().schoolId;
      allow create, update: if isSignedIn() && isOperationalStaff();
      allow delete: if isSignedIn() && isAdmin();
    }

    match /grades/{id} {
      allow read: if isSignedIn() && (
        let staff = getStaffData();
        (staff.schoolId == resource.data.schoolId)
      );
      allow create, update: if isSignedIn() && isOperationalStaff();
      allow delete: if isSignedIn() && isAdmin();
    }
  }
}
