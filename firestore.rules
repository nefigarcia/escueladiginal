
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Reglas de Seguridad Centralizadas
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Función optimizada para obtener datos del staff sin recursión
    function getStaffData() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data;
    }

    function isStaff() {
      let role = getStaffData().role;
      return role == 'Administrador' || role == 'Academico';
    }

    function isAdmin() {
      return getStaffData().role == 'Administrador';
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    match /staff_roles/{userId} {
      allow read, write: if isSignedIn();
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isStaff();
      
      match /payments/{paymentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && isStaff();
      }
    }

    match /psychology_reports/{reportId} {
      // Regla simplificada para permitir el listado basándose en el rol
      // La seguridad por escuela se garantiza mediante los filtros de la consulta (query)
      allow list: if isSignedIn() && isStaff();
      
      allow get: if isSignedIn() && resource.data.schoolId == getStaffData().schoolId;
      allow create: if isSignedIn() && isStaff() && request.resource.data.schoolId == getStaffData().schoolId;
      allow update: if isSignedIn() && isStaff() && resource.data.schoolId == getStaffData().schoolId;
      allow delete: if isSignedIn() && isAdmin();
    }

    match /attendance/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isStaff();
    }

    match /grades/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isStaff();
    }

    match /fee_types/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
    
    match /schedules/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isStaff();
    }
  }
}
