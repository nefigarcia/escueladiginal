
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Escuela Digital MX - Reglas Multi-tenant Optimizadas
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Acceso directo a perfil para evitar latencia en consultas de listado
    function getUserSchool() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data.schoolId;
    }

    function isStaff() {
      let role = get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data.role;
      return role == 'Administrador' || role == 'Academico';
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/staff_roles/$(request.auth.uid)).data.role == 'Administrador';
    }

    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }

    match /staff_roles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /students/{studentId} {
      // Regla de lectura: permite leer si el alumno es de la misma escuela o es el propio alumno logueado
      allow read: if isSignedIn() && (getUserSchool() == resource.data.schoolId || request.auth.uid == studentId);
      allow write: if isSignedIn() && isStaff();
      
      match /payments/{paymentId} {
        allow read: if isSignedIn() && (getUserSchool() == get(/databases/$(database)/documents/students/$(studentId)).data.schoolId || request.auth.uid == studentId);
        allow write: if isSignedIn() && isStaff();
      }
    }

    match /psychology_reports/{reportId} {
      // Regla simplificada para permitir listados (Query-friendly)
      // Firestore exige que el filtro schoolId esté presente en la consulta del cliente
      allow read: if isSignedIn() && isStaff() && resource.data.schoolId == getUserSchool();
      allow create, update: if isSignedIn() && isStaff() && request.resource.data.schoolId == getUserSchool();
      allow delete: if isSignedIn() && isAdmin();
    }

    match /attendance/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getUserSchool();
      allow write: if isSignedIn() && isStaff();
    }

    match /grades/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.schoolId == getUserSchool());
      allow write: if isSignedIn() && isStaff();
    }

    match /fee_types/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getUserSchool();
      allow write: if isSignedIn() && isAdmin();
    }
    
    match /schedules/{id} {
      allow read: if isSignedIn() && resource.data.schoolId == getUserSchool();
      allow write: if isSignedIn() && isStaff();
    }
  }
}
